#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
		zmk,kscan = &kscan0;
        zmk,phsyical-layout = &default_layout;
	};
	kscan0: kscan0 {
	  compatible = "zmk,kscan-gpio-matrix";
	  diode-direction = "col2row";
	  wakeup-source;

	  row-gpios
	  	= <&pro_micro 17 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
	  	, <&pro_micro 20 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
	  	, <&pro_micro 22 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
		;
	};
	default_layout: default_layout {
	  compatible = "zmk,phsyical-layout";
	  display-name = "Default Layout";
	  transform = <&default_transform>;

	  keys
		= <&key_physical_attrs 100 100    0   61       0     0     0>
        , <&key_physical_attrs 100 100  100   28       0     0     0>
		, <&key_physical_attrs 100 100  100   28       0     0     0>
		, <&key_physical_attrs 100 100  100   28       0     0     0>
		, <&key_physical_attrs 100 100  100   28       0     0     0>
		, <&key_physical_attrs 100 100  100   28       0     0     0>
		, <&key_physical_attrs 100 100  100   28       0     0     0>
		, <&key_physical_attrs 100 100  100   28       0     0     0>
		, <&key_physical_attrs 100 100  100   28       0     0     0>
		;
	};

	default_transform: keymap_transform0 {
		compatible = "zmk,matrix_transform";
		columns = <3>;
		rows = <3>;
		map = <
	  		RC(0,0) RC(0,1) RC(0,2) 
	  		RC(1,0) RC(1,1) RC(1,2)
	  		RC(2,0) RC(2,1) RC(2,2)
		>;
  	};


};
